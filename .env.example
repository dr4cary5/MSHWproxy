# MSHW-proxy Environment Configuration
# Copy to .env before running

NGROK_AUTH_TOKEN=your_ngrok_auth_token
# NGROK_HOSTNAME=your_custom_domain.ngrok-free.app  # Leave empty for dynamic URL

DASHBOARD_PASS=your_strong_dashboard_password
TTY_ENABLED=true
TTY_AUTH=your_strong_dashboard_password

PROXY_PORT=8080
PROXY_TIMEOUT=30
MAX_CONCURRENT=5
MAX_RESPONSE_MB=50

CF_STRATEGY=auto  # auto | headers_only | cookie_inject | manual_fallback

LOG_LEVEL=info
LOG_WS=true
