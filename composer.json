{
  "name": "dr4cary5/mshw-proxy",
  "description": "Modern Shadow PHProxy - Ephemeral PHP proxy for GitHub Actions + ngrok",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "dr4cary5",
      "homepage": "https://github.com/dr4cary5"
    }
  ],
  "require": {
    "php": "^8.2",
    "symfony/http-client": "^6.4",
    "symfony/dom-crawler": "^6.4",
    "symfony/css-selector": "^6.4",
    "guzzlehttp/psr7": "^2.6",
    "masterminds/html5": "^2.9",
    "vlucas/phpdotenv": "^5.6",
    "psr/http-message": "^2.0",
    "psr/http-factory": "^1.0"
  },
  "require-dev": {
    "pestphp/pest": "^2.34"
  },
  "autoload": {
    "psr-4": {
      "MSHW\\Proxy\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "scripts": {
    "test": "pest",
    "start": "php -S 0.0.0.0:8080 -t public/"
  }
}
